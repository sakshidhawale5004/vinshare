# Firebase Configuration
# Go to Firebase Console -> Project Settings -> General -> Your Apps -> Firebase SDK snippet
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# Firebase Admin Configuration (For server functions like email sending)
# Go to Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Copy the entire JSON content here, or set it in your Vercel Environment Variables.
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "..."}'

# Lovable API Key for Email Sending (optional)
LOVABLE_API_KEY=""
LOVABLE_EMAIL_SENDER_DOMAIN=""
